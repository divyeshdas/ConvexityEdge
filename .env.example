# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=convexity
POSTGRES_PASSWORD=convexity_secret
POSTGRES_DB=convexityedge
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
SECRET_KEY=change_me_in_production
CORS_ORIGINS=["http://localhost:3000"]

# ── Market Data ───────────────────────────────────────────────────────────────
MARKET_DATA_PROVIDER=yfinance
CHAIN_REFRESH_INTERVAL=60          # seconds

# ── Risk-Free Rate ────────────────────────────────────────────────────────────
RISK_FREE_RATE=0.0525              # 10-yr US treasury approximate

# ── Quant Engine ─────────────────────────────────────────────────────────────
IV_SOLVER_MAX_ITERATIONS=100
IV_SOLVER_TOLERANCE=1e-6
CACHE_TTL=60                       # Redis TTL in seconds
